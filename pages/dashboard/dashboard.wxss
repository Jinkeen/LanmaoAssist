.container {
  padding: 20rpx 24rpx;
  min-height: 100vh;
  background: #f5f3f0;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  padding: 20rpx 0 16rpx;
}

/* 周期切换 */
.period-bar {
  display: flex;
  background: #e8e4de;
  border-radius: 10rpx;
  padding: 6rpx;
  margin-bottom: 20rpx;
}

.period-btn {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  font-size: 28rpx;
  color: #8c857b;
  border-radius: 8rpx;
  transition: all 0.2s;
}

.period-btn.active {
  background: #fff;
  color: #c8844a;
  font-weight: bold;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

/* 概览 */
.summary-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.summary-card {
  flex: 1;
  text-align: center;
  padding: 20rpx 12rpx;
}

.s-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.s-val {
  font-size: 32rpx;
  font-weight: bold;
  color: #c8844a;
}

/* 图表 */
.chart-card {
  padding: 24rpx;
}

.chart-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #555;
  margin-bottom: 24rpx;
}

.chart-area {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 320rpx;
  padding-bottom: 30rpx;
}

.bar-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.bar-val {
  font-size: 18rpx;
  color: #999;
  margin-bottom: 6rpx;
  white-space: nowrap;
}

.bar {
  width: 32rpx;
  background: linear-gradient(to top, #c8844a, #d4a574);
  border-radius: 6rpx 6rpx 0 0;
  min-height: 4rpx;
  transition: height 0.4s ease;
}

.bar-label {
  font-size: 20rpx;
  color: #888;
  margin-top: 10rpx;
}

/* 曲线图 */
.chart-wrap {
  width: 100%;
  height: 380rpx;
  position: relative;
}

.line-canvas {
  width: 100%;
  height: 100%;
}

.chart-tip {
  position: absolute;
  background: rgba(0,0,0,0.75);
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 6rpx;
  white-space: nowrap;
  transform: translateX(-50%);
  pointer-events: none;
  z-index: 10;
}

.chart-empty {
  text-align: center;
  padding: 60rpx 0;
  color: #bbb;
  font-size: 28rpx;
}
