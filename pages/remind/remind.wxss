.section-title { font-size: 34rpx; font-weight: 700; padding: 30rpx 28rpx 0; }
.section-desc { font-size: 26rpx; color: var(--text-light); padding: 8rpx 28rpx 0; }

.remind-card { margin: 20rpx; }
.remind-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.remind-room { font-size: 34rpx; font-weight: 700; }
.tag-warn { background: #fef7ec; color: #c88830; padding: 6rpx 18rpx; border-radius: 8rpx; font-size: 22rpx; }

.remind-info { display: flex; flex-direction: column; gap: 6rpx; font-size: 26rpx; color: var(--text-secondary); margin-bottom: 20rpx; }

.remind-bill { display: flex; gap: 16rpx; margin-bottom: 20rpx; }
.bill-item {
  flex: 1; background: var(--bg); border-radius: 12rpx;
  padding: 16rpx; text-align: center;
}
.bill-label { display: block; font-size: 22rpx; color: var(--text-light); margin-bottom: 6rpx; }
.bill-val { font-size: 28rpx; font-weight: 600; }
.bill-val.price { color: var(--primary); }

.remind-actions { display: flex; justify-content: flex-end; }
