.section-title { font-size: 34rpx; font-weight: 700; padding: 30rpx 28rpx 16rpx; }

.field { display: flex; justify-content: space-between; align-items: center; padding: 28rpx 0; border-bottom: 1rpx solid var(--border); }
.field:last-child { border-bottom: none; }
.field-label { flex-shrink: 0; min-width: 180rpx; font-size: 28rpx; }
.field-val { flex: 1; text-align: right; font-size: 28rpx; }
.field-val.placeholder { color: var(--text-light); }
.field-arrow { font-size: 28rpx; color: var(--text-light); margin-left: 8rpx; }
.field-input { flex: 1; text-align: right; font-size: 28rpx; color: var(--text); }

.picker-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.3); z-index: 100; }
.picker-panel {
  position: fixed; bottom: 0; left: 0; right: 0; z-index: 101;
  background: var(--card); border-radius: 24rpx 24rpx 0 0;
  max-height: 600rpx; padding: 28rpx;
}
.picker-title { font-size: 30rpx; font-weight: 600; margin-bottom: 20rpx; }
.picker-list { max-height: 480rpx; }
.picker-item { padding: 24rpx; font-size: 28rpx; border-radius: 12rpx; margin-bottom: 8rpx; }
.picker-item.active { background: var(--primary-light); color: var(--primary); font-weight: 600; }

.submit-bar { padding: 32rpx 28rpx; }
.submit-bar button { width: 100%; }
.container { padding-bottom: 160rpx; }
