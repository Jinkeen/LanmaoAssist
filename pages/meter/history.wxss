.section-title { font-size: 34rpx; font-weight: 700; padding: 30rpx 28rpx 16rpx; }

.record-item { padding: 20rpx 0; border-bottom: 1rpx solid var(--border); }
.record-item:last-child { border-bottom: none; }
.rec-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.rec-room { font-size: 30rpx; font-weight: 600; }
.rec-month { font-size: 24rpx; color: var(--text-light); }

.rec-body { display: flex; gap: 16rpx; }
.rec-col {
  flex: 1; background: var(--bg); border-radius: 12rpx;
  padding: 16rpx; text-align: center;
}
.rec-label { display: block; font-size: 22rpx; color: var(--text-light); margin-bottom: 6rpx; }
.rec-val { font-size: 28rpx; font-weight: 600; }
.rec-val.price { color: var(--primary); }
