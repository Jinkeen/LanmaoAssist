.section-title { font-size: 34rpx; font-weight: 700; padding: 30rpx 28rpx 16rpx; }
.section-subtitle { font-size: 28rpx; font-weight: 600; margin-bottom: 20rpx; display: block; }

.info-row { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 0; border-bottom: 1rpx solid var(--border); }
.info-row:last-child { border-bottom: none; }
.info-label { color: var(--text-light); }
.info-val { font-weight: 500; }
.info-val.bolder { font-weight: 700; font-size: 30rpx; }

.field-row { display: flex; gap: 24rpx; }
.meter-item { flex: 1; }
.meter-label { display: block; font-size: 26rpx; margin-bottom: 12rpx; }
.meter-input {
  background: var(--bg); border-radius: 12rpx; padding: 20rpx;
  font-size: 30rpx; width: 100%; box-sizing: border-box;
}

.field { display: flex; justify-content: space-between; align-items: center; padding: 32rpx 28rpx; }
.field-label { flex-shrink: 0; min-width: 100rpx; }
.field-input { flex: 1; text-align: right; font-size: 28rpx; }

.notice { text-align: center; color: var(--warning); font-size: 26rpx; padding: 24rpx; }
.submit-bar { padding: 32rpx 28rpx; }
.submit-bar button { width: 100%; }
