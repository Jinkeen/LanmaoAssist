/* 看板样式 */

.container {
  padding-bottom: 40rpx;
}

/* 顶部 */
.header {
  padding: 40rpx 28rpx 20rpx;
}
.header-date {
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 8rpx;
}
.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text);
}

/* 数据卡片 */
.stat-item {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  transition: all 0.2s;
}
.stat-item:active {
  background: rgba(0,0,0,0.03);
  border-radius: 12rpx;
}
.stat-val {
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1.2;
}
.stat-val.rented  { color: var(--danger); }
.stat-val.empty   { color: var(--success); }
.stat-val.cleaning{ color: var(--warning); }
.stat-label {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 4rpx;
}
.stat-divider {
  width: 2rpx;
  background: var(--border);
  margin: 8rpx 0;
}

/* 快捷操作 */
.quick-section {
  padding: 24rpx 20rpx;
}
.section-label {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  display: block;
  color: var(--text);
}
.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}
.q-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
}
.icon-sign  { background: #fdf3ed; }
.icon-renew { background: #edf5e8; }
.icon-out   { background: #fef7ec; }
.icon-meter { background: #eaf0f7; }

/* 提醒标题栏 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 28rpx 0;
}
.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
}
.section-more {
  font-size: 26rpx;
  color: var(--primary);
}

/* 提醒列表 */
.remind-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}
.remind-item:last-child { border-bottom: none; }
.remind-room {
  font-size: 30rpx;
  font-weight: 600;
}
.remind-tenant {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 4rpx;
}
.remind-right { text-align: right; }
.remind-date {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 6rpx;
}
.tag-warn {
  background: #fef7ec;
  color: #c88830;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

/* 截图录入 */
.upload-card {
  text-align: center;
  padding: 48rpx 32rpx;
  background: linear-gradient(135deg, #fdf8f4, #faf3ec);
  border: 2rpx solid #e8d5c4;
}
.upload-icon { font-size: 64rpx; margin-bottom: 16rpx; }
.upload-title { font-size: 32rpx; font-weight: 700; color: var(--primary); margin-bottom: 8rpx; }
.upload-desc { font-size: 24rpx; color: var(--text-light); }

/* 房源弹窗 */
.room-modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.45);
  z-index: 100;
}
.room-modal {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  top: 15%;
  bottom: 15%;
  background: #fff;
  border-radius: 20rpx;
  z-index: 101;
  display: flex;
  flex-direction: column;
}
.room-modal-header {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx 16rpx;
  border-bottom: 1rpx solid var(--border);
}
.room-modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
}
.room-modal-count {
  font-size: 24rpx;
  color: var(--text-light);
  margin-left: 12rpx;
}
.room-modal-close {
  margin-left: auto;
  font-size: 32rpx;
  color: var(--text-light);
  padding: 8rpx 12rpx;
}
.room-modal-list {
  flex: 1;
  padding: 8rpx 0;
}
.room-modal-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 28rpx;
  border-bottom: 1rpx solid #f5f3f0;
}
.room-modal-name {
  font-size: 28rpx;
  color: var(--text);
}
.room-modal-del {
  font-size: 24rpx;
  color: #e06060;
  padding: 6rpx 16rpx;
  border: 1rpx solid #e06060;
  border-radius: 8rpx;
}
.room-modal-empty {
  text-align: center;
  padding: 80rpx 0;
  color: #ccc;
  font-size: 28rpx;
}
