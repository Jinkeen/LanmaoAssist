<view class="container">
  <view class="section-title">密码锁管理</view>

  <view class="card field" bindtap="onShowPicker">
    <text class="field-label">选择房间</text>
    <text class="field-val {{selectedRoom ? '' : 'placeholder'}}">{{selectedRoom || '点击选择'}}</text>
    <text class="field-arrow">›</text>
  </view>

  <view class="picker-mask" wx:if="{{showPicker}}" bindtap="onShowPicker"></view>
  <view class="picker-panel" wx:if="{{showPicker}}">
    <view class="picker-title">选择房间</view>
    <scroll-view scroll-y class="picker-list">
      <view wx:for="{{rooms}}" wx:key="index"
        class="picker-item {{selectedRoomIdx === index ? 'active' : ''}}"
        data-index="{{index}}" bindtap="onSelectRoom">{{item}}</view>
    </scroll-view>
  </view>

  <view class="card" wx:if="{{selectedRoom && !generated}}">
    <view class="gen-hint">
      <text class="gen-icon">🔑</text>
      <text class="gen-text">点击生成{{selectedRoom}}的门锁密码</text>
    </view>
    <button class="btn-primary" bindtap="onGenerate">生成密码</button>
  </view>

  <view class="card" wx:if="{{generated}}">
    <view class="password-display">
      <text class="pwd-label">房间密码</text>
      <view class="pwd-box">
        <text class="pwd-val">{{password}}</text>
        <text class="pwd-hint">（有效期至退房日）</text>
      </view>
    </view>

    <view class="copy-preview">
      <view class="preview-title">复制内容预览</view>
      <view class="preview-content">{{copyText}}</view>
    </view>

    <view class="pwd-actions">
      <button class="btn-primary" bindtap="onCopy">一键复制转发</button>
      <button class="btn-outline" bindtap="onRegenerate" style="margin-top:16rpx">重新生成</button>
    </view>
  </view>
</view>
