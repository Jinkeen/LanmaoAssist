.section-title { font-size: 34rpx; font-weight: 700; padding: 30rpx 28rpx 16rpx; }

.field { display: flex; justify-content: space-between; align-items: center; padding: 32rpx 28rpx; }
.field-label { flex-shrink: 0; min-width: 160rpx; font-size: 28rpx; }
.field-val { flex: 1; text-align: right; font-size: 28rpx; }
.field-val.placeholder { color: var(--text-light); }
.field-arrow { font-size: 28rpx; color: var(--text-light); margin-left: 8rpx; }

.picker-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.3); z-index: 100; }
.picker-panel {
  position: fixed; bottom: 0; left: 0; right: 0; z-index: 101;
  background: var(--card); border-radius: 24rpx 24rpx 0 0;
  max-height: 600rpx; padding: 28rpx;
}
.picker-title { font-size: 30rpx; font-weight: 600; margin-bottom: 20rpx; }
.picker-list { max-height: 480rpx; }
.picker-item { padding: 24rpx; font-size: 28rpx; border-radius: 12rpx; margin-bottom: 8rpx; }
.picker-item.active { background: var(--primary-light); color: var(--primary); font-weight: 600; }

/* 生成按钮区 */
.gen-hint { display: flex; flex-direction: column; align-items: center; gap: 16rpx; margin-bottom: 24rpx; }
.gen-icon { font-size: 64rpx; }
.gen-text { font-size: 26rpx; color: var(--text-light); }
.card button { width: 100%; }

/* 密码显示 */
.password-display { text-align: center; margin-bottom: 28rpx; }
.pwd-label { font-size: 26rpx; color: var(--text-light); display: block; margin-bottom: 12rpx; }
.pwd-box { background: var(--primary-light); border-radius: 16rpx; padding: 28rpx; }
.pwd-val { font-size: 56rpx; font-weight: 800; color: var(--primary); letter-spacing: 8rpx; }
.pwd-hint { display: block; font-size: 22rpx; color: var(--text-light); margin-top: 8rpx; }

.copy-preview { background: var(--bg); border-radius: 14rpx; padding: 24rpx; margin-bottom: 24rpx; }
.preview-title { font-size: 24rpx; color: var(--text-light); margin-bottom: 12rpx; }
.preview-content { font-size: 28rpx; line-height: 1.8; white-space: pre-line; color: var(--text); }
