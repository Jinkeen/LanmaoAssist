.profile-header {
  text-align: center; padding: 60rpx 0 40rpx;
}
.avatar {
  width: 120rpx; height: 120rpx; border-radius: 30rpx;
  background: var(--primary-light);
  display: flex; align-items: center; justify-content: center;
  font-size: 56rpx; margin: 0 auto 20rpx;
}
.profile-name { font-size: 36rpx; font-weight: 700; margin-bottom: 8rpx; }
.profile-desc { font-size: 26rpx; color: var(--text-light); }

.menu-card { margin-top: 20rpx; }

.menu-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--border);
}
.menu-item:last-child { border-bottom: none; }
.menu-left { display: flex; align-items: center; gap: 20rpx; }
.menu-icon { font-size: 36rpx; }
.menu-title { font-size: 30rpx; }
.menu-arrow { font-size: 32rpx; color: var(--text-light); }
