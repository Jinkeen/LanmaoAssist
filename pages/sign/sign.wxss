.section-title { font-size: 34rpx; font-weight: 700; padding: 30rpx 28rpx 16rpx; }

.card.field { display: flex; justify-content: space-between; align-items: center; padding: 32rpx 28rpx; margin-bottom: 0; }
.field-label { font-size: 28rpx; color: var(--text); flex-shrink: 0; min-width: 140rpx; }
.field-val { flex: 1; text-align: right; font-size: 28rpx; color: var(--text); }
.field-val.placeholder { color: var(--text-light); }
.field-arrow { font-size: 28rpx; color: var(--text-light); margin-left: 8rpx; }
.field-input { flex: 1; text-align: right; font-size: 28rpx; }
.field-row { display: flex; gap: 20rpx; }
.field-half { flex: 1; padding: 32rpx 0; }
.field-half .field-label { display: block; margin-bottom: 12rpx; }

/* 房间选择弹层 */
.picker-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.3); z-index: 100; }
.picker-panel {
  position: fixed; bottom: 0; left: 0; right: 0; z-index: 101;
  background: var(--card); border-radius: 24rpx 24rpx 0 0;
  max-height: 600rpx; padding: 28rpx;
}
.picker-title { font-size: 30rpx; font-weight: 600; margin-bottom: 20rpx; }
.picker-list { max-height: 480rpx; }
.picker-item { padding: 24rpx; font-size: 28rpx; border-radius: 12rpx; margin-bottom: 8rpx; }
.picker-item.active { background: var(--primary-light); color: var(--primary); font-weight: 600; }

/* 来源 */
.source-row { display: flex; gap: 16rpx; }
.source-btn {
  padding: 12rpx 28rpx; border-radius: 10rpx; font-size: 26rpx;
  background: var(--bg); color: var(--text-secondary);
}
.source-btn.active { background: var(--primary-light); color: var(--primary); font-weight: 600; }

/* 提交 */
.submit-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 24rpx 28rpx; background: var(--card);
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.04);
}
.submit-bar button { width: 100%; }
.preview-text {
  text-align: center; font-size: 26rpx; color: var(--primary);
  margin-bottom: 16rpx; font-weight: 500;
}
.container { padding-bottom: 200rpx; }
